<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<title>Capture as Bolinhas</title>

<style>
body{
    margin:0;
    overflow:hidden;
    font-family:Arial,sans-serif;
    background:#9fdcff;
    transition:background 1s;
}

#hud{
    position:fixed;
    top:15px;
    left:15px;
    font-size:24px;
    font-weight:bold;
    z-index:1000;
}

.bola{
    position:absolute;
    width:60px;
    height:60px;
    border-radius:50%;
    background:white;
    border:2px solid black;
    display:flex;
    justify-content:center;
    align-items:center;
    cursor:pointer;
    font-size:34px;
}

.bola img{
    width:100%;
    height:100%;
    border-radius:50%;
    pointer-events:none;
}

.treme{
    animation:tremer .05s infinite;
}

@keyframes tremer{
    0%{transform:translate(2px,1px);}
    25%{transform:translate(-2px,-1px);}
    50%{transform:translate(2px,-2px);}
    75%{transform:translate(-2px,2px);}
    100%{transform:translate(1px,-1px);}
}

#mensagem{
    position:fixed;
    inset:0;
    background:rgba(0,0,0,.6);
    color:white;
    display:flex;
    justify-content:center;
    align-items:center;
    font-size:50px;
    z-index:999;
}
</style>

</head>
<body>

<div id="hud">
Fase: <span id="fase">1</span><br>
Pontos: <span id="pontos">0</span>/<span id="meta">10</span>
</div>

<div id="mensagem">
Clique para começar
</div>

<script>

let fase=1;
let pontos=0;
let meta=10;
let emoji="😊";
let velocidade=700;
let intervalo;

document.body.onclick=function(){

    if(document.getElementById("mensagem")){
        document.getElementById("mensagem").remove();
        iniciar();
        document.body.onclick=null;
    }

}

function iniciar(){

    atualizarHUD();

    intervalo=setInterval(criarBola,velocidade);

}

function atualizarHUD(){

    document.getElementById("fase").textContent=fase;
    document.getElementById("pontos").textContent=pontos;
    document.getElementById("meta").textContent=meta;

}

function criarBola(){

    const bola=document.createElement("div");
    bola.className="bola";

    const tamanho=50+Math.random()*20;

    bola.style.width=tamanho+"px";
    bola.style.height=tamanho+"px";

    bola.style.left=Math.random()*(window.innerWidth-tamanho)+"px";
    bola.style.top=Math.random()*(window.innerHeight-tamanho)+"px";

    if(fase==3){

        bola.classList.add("treme");
        bola.innerHTML='<img src="emily.png">';

    }else{

        bola.textContent=emoji;

    }

    bola.onclick=function(e){

        e.stopPropagation();

        pontos++;

        atualizarHUD();

        bola.remove();

        if(fase==3){

            if(pontos%50==0){

                document.body.style.background=
                "rgb("+(20+Math.random()*20)+","+
                (20+Math.random()*20)+","+
                (20+Math.random()*20)+")";

            }

            if(pontos==111 || pontos==222 || pontos==333 || pontos==444 || pontos==555){

                alert("Continue.");

            }

        }

        if(pontos>=meta){

            proximaFase();

        }

    }

    document.body.appendChild(bola);

    setTimeout(()=>{

        bola.remove();

    },1500);

}

function proximaFase(){

    clearInterval(intervalo);

    document.querySelectorAll(".bola").forEach(b=>b.remove());

    if(fase==1){

        fase=2;
        pontos=0;
        meta=15;
        emoji="😐";
        velocidade=450;

        alert("Fase 2");

    }else if(fase==2){

        fase=3;
        pontos=0;
        meta=666;
        velocidade=120;

        document.body.style.background="#222";

        alert("Fase 3");

    }else{

        document.body.innerHTML=`
        <div style="
        display:flex;
        justify-content:center;
        align-items:center;
        flex-direction:column;
        width:100vw;
        height:100vh;
        background:black;
        color:white;
        font-size:40px;
        ">
            <h1>Fim.</h1>
            <img src="emily.png" style="width:400px;">
        </div>
        `;

        return;

    }

    atualizarHUD();

    intervalo=setInterval(criarBola,velocidade);

}

</script>

</body>
</html>
